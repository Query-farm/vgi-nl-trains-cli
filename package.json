{
  "name": "haybarn-vgi-nl-trains-cli",
  "version": "0.1.0",
  "description": "Live Dutch railway (NS) departure/arrival dashboard in your terminal — an Ink TUI over the vgi DuckDB extension.",
  "type": "module",
  "bin": {
    "haybarn-vgi-nl-trains-cli": "dist/cli.js",
    "vgi-nl-trains": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild source/cli.jsx --bundle --platform=node --target=node18 --format=esm --packages=external --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\" && chmod +x dist/cli.js",
    "dev": "tsx source/cli.jsx",
    "start": "node dist/cli.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "ns",
    "nederlandse-spoorwegen",
    "trains",
    "railway",
    "departures",
    "netherlands",
    "duckdb",
    "vgi",
    "ink",
    "tui",
    "cli"
  ],
  "author": "Query.Farm LLC (https://query.farm)",
  "license": "MIT",
  "homepage": "https://github.com/Query-farm/vgi-nl-trains-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Query-farm/vgi-nl-trains-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Query-farm/vgi-nl-trains-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@haybarn/ext-vgi-h1-5-3": "^202605.22.43830",
    "@haybarn/node-api": "1.5.3-rc2",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "string-width": "^8.2.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2"
  }
}
